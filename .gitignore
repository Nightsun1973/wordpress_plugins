# =============================================================================
# Umbrella Git (wordpress_plugins): shared tooling + live-plugins manifest only
# =============================================================================
# Per-repo development trees: primarily under plugins/ (e.g. plugins/client/,
# plugins/archive/, plugins/chameleon/ when relocated). Top-level chameleon/
# may remain during migration. Those trees are NOT tracked here — each product
# folder typically has its own .git.
# =============================================================================

# --- Per-repo source trees (own Git remotes) ---
/plugins/
/chameleon/
# Legacy top-level buckets (ignore if recreated at repo root)
/client/
/archive/

# --- Optional root artefact ---
/dist/

# --- Secrets (never commit) ---
scripts/live-plugins-ftp.env

# --- OS / editor noise ---
Thumbs.db
Desktop.ini
.DS_Store
*.stackdump
