# Copy to live-plugins-ftp.env (gitignored). SFTP (SSH) — not FTP.

# Preferred names:
CHAMELEON_LIVE_PLUGINS_SFTP_HOST=your-server.example.com
CHAMELEON_LIVE_PLUGINS_SFTP_USER=
CHAMELEON_LIVE_PLUGINS_SFTP_PASSWORD=
CHAMELEON_LIVE_PLUGINS_SFTP_REMOTE_DIR=/applications/yourapp/public_html/wp-content/uploads/plugin-repo

# First-time connect (host key prompt): set to 1 once, then remove if you prefer stricter checks
# CHAMELEON_LIVE_PLUGINS_SFTP_ACCEPT_HOST_KEY=1

# Optional:
# CHAMELEON_LIVE_PLUGINS_SFTP_PORT=22
# CHAMELEON_LIVE_PLUGINS_SFTP_KEY_FILE=C:\path\to\id_ed25519
# CHAMELEON_LIVE_PLUGINS_SFTP_CONNECTION_TIMEOUT_SEC=120
# CHAMELEON_LIVE_PLUGINS_SFTP_NO_STRICT_HOSTKEY=1
# Set to 1 only if you must keep remote-only zips (default: delete remote .zip files not present in local plugins-live/)
# CHAMELEON_LIVE_PLUGINS_SFTP_NO_PRUNE=1

# Legacy aliases (still read if SFTP_* unset):
# CHAMELEON_LIVE_PLUGINS_FTP_HOST=
# CHAMELEON_LIVE_PLUGINS_FTP_USER=
# CHAMELEON_LIVE_PLUGINS_FTP_PASSWORD=
# CHAMELEON_LIVE_PLUGINS_FTP_REMOTE_DIR=
