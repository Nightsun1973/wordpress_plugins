# =============================================================================
# Umbrella Git (wordpress_plugins): shared tooling + plugins-live manifest only
# =============================================================================
# Per-repo development trees: under plugins-dev/ (e.g. plugins-dev/chameleon/,
# plugins-dev/archive/). Top-level chameleon/ may remain during migration.
# Those trees are NOT tracked here — each product folder typically has its own .git.
# =============================================================================

# --- Per-repo source trees (own Git remotes) ---
/plugins-dev/
/chameleon/
# Legacy top-level buckets (ignore if recreated at repo root)
/client/
/archive/

# --- Optional root artefact ---
/dist/

# --- Secrets (never commit) ---
scripts/live-plugins-ftp.env

# --- OS / editor noise ---
Thumbs.db
Desktop.ini
.DS_Store
*.stackdump
